<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucv.restaurante.controller.MesaController" spacing="12" style="-fx-padding:18; -fx-background-color:#F6F7F9;" prefWidth="700" prefHeight="500">
    <Label text="Restaurante | Mesas" style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#172026;"/>
    <HBox spacing="10"><TextField fx:id="txtFiltro" promptText="Buscar mesa o estado" prefWidth="260"/><Button text="Buscar" onAction="#onBuscar"/></HBox>
    <HBox spacing="10"><Button text="+ Nueva mesa" onAction="#onCrear"/><Button text="Editar" onAction="#onEditar"/><Button text="Eliminar" onAction="#onEliminar"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblTotal"/></HBox>
    <TableView fx:id="tableView" VBox.vgrow="ALWAYS"><columns><TableColumn fx:id="colId" text="ID" prefWidth="70"/><TableColumn fx:id="colNumero" text="Numero" prefWidth="120"/><TableColumn fx:id="colCapacidad" text="Capacidad" prefWidth="140"/><TableColumn fx:id="colEstado" text="Estado" prefWidth="180"/></columns></TableView>
</VBox>
