<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucv.restaurante.controller.PedidoDetalleController" spacing="12" style="-fx-padding:18; -fx-background-color:#F6F7F9;" prefWidth="980" prefHeight="560">
    <Label text="Restaurante | Detalle de pedidos" style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#172026;"/>
    <HBox spacing="10"><TextField fx:id="txtFiltro" promptText="Buscar pedido, producto o ID producto" prefWidth="310"/><Button text="Buscar" onAction="#onBuscar"/></HBox>
    <HBox spacing="10"><Button text="+ Nuevo detalle" onAction="#onCrear"/><Button text="Editar" onAction="#onEditar"/><Button text="Eliminar" onAction="#onEliminar"/><Region HBox.hgrow="ALWAYS"/><Label fx:id="lblTotal"/></HBox>
    <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colPedido" text="Pedido" prefWidth="80"/>
            <TableColumn fx:id="colProductoId" text="ID Producto" prefWidth="95"/>
            <TableColumn fx:id="colProducto" text="Producto" prefWidth="260"/>
            <TableColumn fx:id="colCantidad" text="Cantidad" prefWidth="90"/>
            <TableColumn fx:id="colPrecio" text="Precio unit." prefWidth="110"/>
            <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="110"/>
        </columns>
    </TableView>
</VBox>
