<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucv.restaurante.controller.PedidoFormController" spacing="14" style="-fx-padding:22; -fx-background-color:#F6F7F9;" prefWidth="760" prefHeight="620">
    <Label fx:id="lblTitulo" text="Pedido" style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#172026;"/>
    <GridPane hgap="12" vgap="10"><columnConstraints><ColumnConstraints prefWidth="120" halignment="RIGHT"/><ColumnConstraints prefWidth="220"/><ColumnConstraints prefWidth="100" halignment="RIGHT"/><ColumnConstraints prefWidth="220"/></columnConstraints>
        <Label text="Mesa: *" GridPane.rowIndex="0" GridPane.columnIndex="0"/><TextField fx:id="txtMesa" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="Mesero: *" GridPane.rowIndex="0" GridPane.columnIndex="2"/><TextField fx:id="txtMesero" promptText="Nombre exacto" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
        <Label text="Estado: *" GridPane.rowIndex="1" GridPane.columnIndex="0"/><ComboBox fx:id="cboEstado" GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>
    </GridPane>

    <Separator/>
    <Label text="Productos del pedido" style="-fx-font-size:16; -fx-font-weight:bold; -fx-text-fill:#172026;"/>
    <GridPane hgap="10" vgap="10"><columnConstraints><ColumnConstraints prefWidth="120" halignment="RIGHT"/><ColumnConstraints prefWidth="300"/><ColumnConstraints prefWidth="80" halignment="RIGHT"/><ColumnConstraints prefWidth="90"/><ColumnConstraints prefWidth="95"/></columnConstraints>
        <Label text="Producto: *" GridPane.rowIndex="0" GridPane.columnIndex="0"/><ComboBox fx:id="cboProducto" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity"/>
        <Label text="Cantidad: *" GridPane.rowIndex="0" GridPane.columnIndex="2"/><TextField fx:id="txtCantidad" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
        <Button text="Agregar" onAction="#onAgregarDetalle" GridPane.rowIndex="0" GridPane.columnIndex="4" maxWidth="Infinity"/>
        <Label text="Precio unit.: *" GridPane.rowIndex="1" GridPane.columnIndex="0"/><TextField fx:id="txtPrecio" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Button text="Quitar seleccionado" onAction="#onQuitarDetalle" GridPane.rowIndex="1" GridPane.columnIndex="4" maxWidth="Infinity"/>
    </GridPane>

    <TableView fx:id="tblDetalle" prefHeight="240" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colProducto" text="Producto" prefWidth="330"/>
            <TableColumn fx:id="colCantidad" text="Cantidad" prefWidth="100"/>
            <TableColumn fx:id="colPrecio" text="Precio unit." prefWidth="120"/>
            <TableColumn fx:id="colSubtotal" text="Subtotal" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT"><Label fx:id="lblTotalPedido" text="Total: S/ 0.00" style="-fx-font-size:16; -fx-font-weight:bold;"/></HBox>
    <Label fx:id="lblError" visible="false" wrapText="true" style="-fx-text-fill:#EF476F;"/>
    <HBox spacing="10" alignment="CENTER_RIGHT"><Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar"/><Button text="Guardar pedido" onAction="#onGuardar"/></HBox>
</VBox>
