<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ucv.restaurante.controller.MeseroFormController" spacing="14" style="-fx-padding:24; -fx-background-color:#F6F7F9;" prefWidth="460">
    <Label fx:id="lblTitulo" text="Mesero" style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#172026;"/>
    <GridPane hgap="12" vgap="10"><columnConstraints><ColumnConstraints prefWidth="120" halignment="RIGHT"/><ColumnConstraints prefWidth="250"/></columnConstraints>
        <Label text="Nombres: *" GridPane.rowIndex="0" GridPane.columnIndex="0"/><TextField fx:id="txtNombres" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        <Label text="DNI: *" GridPane.rowIndex="1" GridPane.columnIndex="0"/><TextField fx:id="txtDni" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
        <Label text="Telefono:" GridPane.rowIndex="2" GridPane.columnIndex="0"/><TextField fx:id="txtTelefono" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
        <Label text="Activo:" GridPane.rowIndex="3" GridPane.columnIndex="0"/><CheckBox fx:id="chkActivo" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>
    <Label fx:id="lblError" visible="false" style="-fx-text-fill:#EF476F;"/>
    <HBox spacing="10" alignment="CENTER_RIGHT"><Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar"/><Button text="Guardar" onAction="#onGuardar"/></HBox>
</VBox>
