<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.restaurante.controller.MenuController"
      prefWidth="340" prefHeight="520" spacing="12" alignment="TOP_CENTER"
      style="-fx-background-color:#202A32; -fx-padding:26;">

    <Label text="RESTAURANTE" alignment="CENTER" style="-fx-text-fill:white; -fx-font-size:23; -fx-font-weight:bold;">
        <font><Font size="24"/></font>
    </Label>
    <Label text="Sistema de gestion" alignment="CENTER" style="-fx-text-fill:#B8C2CC; -fx-font-size:13;"/>

    <Separator prefWidth="250" style="-fx-background-color:#46535E;"/>

    <Button text="Productos" onAction="#abrirProductos" prefWidth="250" prefHeight="40" style="-fx-background-color:#2F6F73; -fx-text-fill:white; -fx-font-weight:bold;"/>
    <Button text="Mesas" onAction="#abrirMesas" prefWidth="250" prefHeight="40" style="-fx-background-color:#33414B; -fx-text-fill:white; -fx-font-weight:bold;"/>
    <Button text="Meseros" onAction="#abrirMeseros" prefWidth="250" prefHeight="40" style="-fx-background-color:#33414B; -fx-text-fill:white; -fx-font-weight:bold;"/>
    <Button text="Pedidos" onAction="#abrirPedidos" prefWidth="250" prefHeight="40" style="-fx-background-color:#33414B; -fx-text-fill:white; -fx-font-weight:bold;"/>
    <Button text="Facturas" onAction="#abrirFacturas" prefWidth="250" prefHeight="40" style="-fx-background-color:#33414B; -fx-text-fill:white; -fx-font-weight:bold;"/>

    <Region VBox.vgrow="ALWAYS"/>

    <Button text="Salir" onAction="#salir" prefWidth="250" prefHeight="38" style="-fx-background-color:#B94A5A; -fx-text-fill:white; -fx-font-weight:bold;"/>
</VBox>
